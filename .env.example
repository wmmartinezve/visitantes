APP_NAME=Visitantes
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Caracas
APP_URL=https://visitantes.proyectoswm.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_VE

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_LEVEL=info

# Railway PostgreSQL — al vincular el plugin, use DB_URL o las variables PG*
DB_CONNECTION=pgsql
# DB_URL=postgresql://user:pass@host:5432/railway

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
# Fotos Invitados: local (dev) | s3 (Railway + bucket visitantes-anzoategui-prod)
INVITADO_FOTOS_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# Geografía INE en cada deploy (migrate + seed automático en entrypoint si RUN_DEMO_SEED)
# Demo (admin@visitantes.test / password): solo local/testing o RUN_DEMO_SEED=true
RUN_DEMO_SEED=false

# Tokens móvil Sanctum — minutos hasta expiración (10080 = 7 días)
SANCTUM_TOKEN_EXPIRATION=10080

# Correo — necesario para recuperar contraseña (SMTP, Resend, Postmark, etc.)
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@visitantes.proyectoswm.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Google Maps — mapa operativo en /admin (Maps JavaScript API)
GOOGLE_MAPS_API_KEY=

# Amazon S3 — fotos de Invitados (INVITADO_FOTOS_DISK=s3 en producción)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=sa-east-1
AWS_BUCKET=visitantes-anzoategui-prod
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false
