APP_NAME=Visitantes
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/Caracas
APP_URL=https://visitantes.proyectoswm.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_VE

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_LEVEL=info

# Railway PostgreSQL — al vincular el plugin, use DB_URL o las variables PG*
DB_CONNECTION=pgsql
# DB_URL=postgresql://user:pass@host:5432/railway

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database

CACHE_STORE=database

# Primer deploy: RUN_SEED=true carga geografía, demo y admin@visitantes.test
RUN_SEED=false

# Sanctum (app móvil usa tokens Bearer; no requiere dominios stateful extra)
SANCTUM_STATEFUL_DOMAINS=

VITE_APP_NAME="${APP_NAME}"
